# =============================================================================
# Opcional: segundo archivo solo si NO usa .env en el servidor.
# En la mayoría de casos basta con renombrar/copiar esto a .env y ejecutar:
#   docker compose up -d --build
# Si prefiere nombre distinto: docker compose --env-file .env.production up -d --build
# =============================================================================

API_INTERNAL_PORT=3001
NODE_ENV=production

POSTGRES_USER=chatbotcrm
POSTGRES_PASSWORD=DEFINIR_SECRETO_FUERTE
POSTGRES_DB=crm_chatbot

JWT_SECRET=DEFINIR_SECRETO_FUERTE
JWT_EXPIRES_IN=7d

LICENCIA_API_URL=https://su-api-licencias/ejemplo/ValidarLicencia
CODIGO_APLICATIVO=1
EDICION_APLICATIVO=1

API_PORT=3001
# En producción puede omitirse exposición pública de Postgres (no mapear POSTGRES_PORT o use un firewall)
POSTGRES_PORT=5432

PGADMIN_PORT=5050
PGADMIN_DEFAULT_EMAIL=admin@empresa.com
PGADMIN_DEFAULT_PASSWORD=DEFINIR
