# Database Configuration
# En Docker: usar DB_HOST=postgres (nombre del servicio)
# En desarrollo local: usar DB_HOST=localhost
DB_HOST=localhost
DB_PORT=5432
DB_NAME=crm_chatbot
DB_USER=postgres
DB_PASSWORD=postgres

# Server Configuration
PORT=3004
NODE_ENV=development

# JWT (CRM login)
JWT_SECRET=crm-chatbot-secret-change-in-production
JWT_EXPIRES_IN=7d

# Database SSL (for production)
DB_SSL=false

# Licenciamiento API Configuration
LICENCIA_API_URL=http://licensecurity.hginet.co:9502/Api/ValidarLicenciamiento
CODIGO_APLICATIVO=1
EDICION_APLICATIVO=1
