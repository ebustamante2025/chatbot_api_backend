# =============================================================================
# Copiar a .env y reemplazar con tus valores reales. NO subir .env a Git.
# En producción: usar contraseñas y secretos fuertes (openssl rand -base64 48).
# =============================================================================

# PostgreSQL (Docker y backend)
POSTGRES_USER=chatbotcrm
POSTGRES_PASSWORD=cambiar_contraseña_segura
POSTGRES_DB=crm_chatbot

# Backend - Base de datos
# En Docker: DB_HOST=crm-chatbot-postgres | En local: DB_HOST=localhost
DB_HOST=localhost
DB_PORT=5432
DB_NAME=crm_chatbot
DB_USER=chatbotcrm
DB_PASSWORD=cambiar_contraseña_segura
DB_SSL=false

# Backend - Servidor
PORT=3004
NODE_ENV=development

# JWT (login CRM) - En producción usar un secreto largo: openssl rand -base64 48
JWT_SECRET=cambiar-jwt-secret-en-produccion
JWT_EXPIRES_IN=7d

# CORS (solo producción): orígenes permitidos separados por coma
# Ejemplo: https://crm.tudominio.com,https://tudominio.com
# CORS_ORIGINS=

# Proxy webhooks agente Isa (evita CORS desde el widget). Opcional; por defecto usa las URLs HGInet.
# ISA_REGISTRO_WEBHOOK_URL=https://agentehgi.hginet.com.co/webhook/1986379d-e2f5-4eb3-b925-146875342724
# ISA_AGENT_WEBHOOK_URL=https://agentehgi.hginet.com.co/webhook/72919732-5851-4c49-966f-36f638298c88

# API validación empresas/licencias (HGInet Security Licencia)
# GET ValidarLicencia?IdentificacionEmpresa={nit}
LICENCIA_API_URL=http://atila.hgi.com.co:8880/HGInetSecurityLicencia/Api/HelpHGIApiController/ValidarLicencia
CODIGO_APLICATIVO=1
EDICION_APLICATIVO=1

# Telegram (integración canal TELEGRAM con CRM)
# Crear bot en @BotFather y pegar el token aquí. Webhook: POST /api/telegram/webhook
# En el bot: /registrar, /cambiar o /reiniciar vuelven a pedir NIT y cédula en este chat. Varios números pueden compartir el mismo contacto CRM.
# TELEGRAM_BOT_TOKEN=

# IA360 en chatbot_widget — POST /api/ia360-doc/chat (OpenAI + Notion; mismo criterio que chatbot_Agente)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# NOTION_API_KEY=secret_...
# Velocidad IA360 (opcional; por defecto ya es más rápido: 5 rondas, 24 mensajes, ~9k chars/herramienta).
# Más exhaustivo: IA360_MAX_TOOL_ROUNDS=8 IA360_MAX_HISTORY_MESSAGES=40 IA360_MAX_TOOL_RESULT_CHARS=12000
# IA360_MAX_TOOL_ROUNDS=4
# IA360_MAX_HISTORY_MESSAGES=16
# IA360_MAX_TOOL_RESULT_CHARS=7000

# pgAdmin (solo si usas perfil tools)
PGADMIN_DEFAULT_EMAIL=admin@ejemplo.com
PGADMIN_DEFAULT_PASSWORD=cambiar_contraseña_pgadmin
