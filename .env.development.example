# =============================================================================
# SOLO para Docker Compose en su PC (no para npm run dev).
# Copiar: copy .env.development.example .env.development  y editar.
# Arrancar: npm run compose:dev   ó   docker compose --env-file .env.development up -d --build
#
# Para localhost con npm run dev use el archivo .env (plantilla: .env.example), no este.
# =============================================================================

# API dentro del contenedor (debe coincidir con el mapeo de puertos; por defecto 3001)
API_INTERNAL_PORT=3001
NODE_ENV=development

POSTGRES_USER=chatbotcrm
POSTGRES_PASSWORD=cambiar_contraseña_segura
POSTGRES_DB=crm_chatbot

JWT_SECRET=cambiar-jwt-secret-desarrollo
JWT_EXPIRES_IN=7d

LICENCIA_API_URL=http://atila.hgi.com.co:8880/HGInetSecurityLicencia/Api/HelpHGIApiController/ValidarLicencia
CODIGO_APLICATIVO=1
EDICION_APLICATIVO=1

# Puertos publicados en el host (opcional; por defecto los del compose)
API_PORT=3001
POSTGRES_PORT=5432

# pgAdmin (perfil tools): npm run compose:dev:tools
PGADMIN_PORT=5050
PGADMIN_DEFAULT_EMAIL=admin@ejemplo.com
PGADMIN_DEFAULT_PASSWORD=cambiar
