{
  "name": "api-backend",
  "version": "1.0.0",
  "description": "API Backend para CRM ChatBot con PostgreSQL",
  "main": "dist/src/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/src/index.js",
    "kill-port": "powershell -ExecutionPolicy Bypass -File scripts/kill-port.ps1",
    "migrate:latest": "tsx node_modules/knex/bin/cli.js migrate:latest",
    "migrate:rollback": "tsx node_modules/knex/bin/cli.js migrate:rollback",
    "migrate:make": "tsx node_modules/knex/bin/cli.js migrate:make",
    "migrate:status": "tsx node_modules/knex/bin/cli.js migrate:status",
    "seed:run": "tsx node_modules/knex/bin/cli.js seed:run",
    "db:create": "node -r dotenv/config scripts/create-db.js",
    "db:verify": "tsx scripts/verify-db.js"
  },
  "keywords": [
    "api",
    "backend",
    "postgresql",
    "knex"
  ],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=22.18.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "jsonwebtoken": "^9.0.3",
    "knex": "^3.1.0",
    "pg": "^8.13.1",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
